# ============================================================================
# NarraCraft — Environment Configuration
# ============================================================================
# Copy this file to .env and adjust for your machine:
#   cp .env.example .env
#
# This file is read by docker-compose automatically.
# ============================================================================

# ── Server Ports ──
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── GPU Support ──
# Set to "true" only if you have NVIDIA GPU drivers installed
ENABLE_GPU=false

# ── Logging ──
LOG_LEVEL=INFO

# ── YouTube Data API v3 ──
# Required for: video uploads, analytics collection, comment pinning
# Get yours at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=
YOUTUBE_OAUTH_JSON_PATH=/app/data/youtube_oauth.json

# ── Twitch / IGDB ──
# Required for: IGDB game search during franchise onboarding
# Register at: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ── Google Custom Search (optional) ──
# Used for: reference image search during onboarding
# Falls back to DuckDuckGo if not set
# Setup: https://programmablesearchengine.google.com/
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
